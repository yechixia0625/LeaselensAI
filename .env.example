# LeaseLens AI - Environment Configuration

# App
LEASENS_APP_NAME="LeaseLens AI"
LEASENS_DEBUG=true
LEASENS_API_V1_PREFIX="/api/v1"

# Database
LEASENS_DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/leaselens"
LEASENS_DATABASE_POOL_SIZE=20

# Redis
LEASENS_REDIS_URL="redis://localhost:6379/0"

# LLM
LEASENS_LLM_API_KEY="your-zhipu-api-key-here"
LEASENS_LLM_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
LEASENS_LLM_MODEL="glm-4.1v-thinking-flash"
LEASENS_LLM_TIMEOUT_SECONDS=120

# Google Places API (server side only; enable Places API (New))
LEASENS_GOOGLE_PLACES_API_KEY="your-google-places-api-key-here"
LEASENS_GOOGLE_PLACES_SEARCH_RADIUS_METERS=500

# Demo auth for public test environments
LEASENS_DEMO_AUTH_ENABLED=true
LEASENS_DEMO_AUTH_USERNAME="demo"
LEASENS_DEMO_AUTH_PASSWORD="change-me"
LEASENS_DEMO_AUTH_SECRET="change-me-to-a-long-random-string"
LEASENS_DEMO_AUTH_COOKIE_NAME="leaselens_demo_session"

# Agent Concurrency
LEASENS_MAX_CONCURRENT_AGENTS=4
LEASENS_AGENT_LOG_BUFFER_SIZE=50

# SSE
LEASENS_SSE_HEARTBEAT_INTERVAL=15

# Optional: set these when Docker builds require a local HTTP proxy.
DOCKER_BUILD_HTTP_PROXY=""
DOCKER_BUILD_HTTPS_PROXY=""
DOCKER_BUILD_NO_PROXY="localhost,127.0.0.1,::1"
DOCKER_RUNTIME_HTTP_PROXY=""
DOCKER_RUNTIME_HTTPS_PROXY=""
DOCKER_RUNTIME_NO_PROXY="localhost,127.0.0.1,::1,db,redis"

# Docker Compose public Nginx entrypoint
PUBLIC_HTTP_PORT="80"
